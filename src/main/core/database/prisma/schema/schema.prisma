generator client {
  provider        = "prisma-client-js"
  // output          = "../generated"
  previewFeatures = ["multiSchema"]
  // moduleFormat    = "esm"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "../../../../../../docs/table-erd.md"
  title    = "Hydra ERD"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}
